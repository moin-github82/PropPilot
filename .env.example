# ─── EPC Register API (https://epc.opendatacommunities.org) ───────────────────
EPC_API_EMAIL=your_email@example.com
EPC_API_KEY=your_epc_api_key_here

# ─── Land Registry API ────────────────────────────────────────────────────────
# No key needed — public SPARQL endpoint
LAND_REGISTRY_ENDPOINT=https://landregistry.data.gov.uk/data/ppi

# ─── Ofcom Broadband Coverage API ────────────────────────────────────────────
# 1. Register at https://api.ofcom.org.uk
# 2. Go to Products → subscribe to "Broadband Coverage"
# 3. Go to Profile → Subscriptions → click "Show" next to Primary key
OFCOM_SUBSCRIPTION_KEY=your_ofcom_subscription_key_here

# ─── OS Places API (address lookup) ──────────────────────────────────────────
# Register at https://osdatahub.os.uk
OS_PLACES_API_KEY=your_os_places_key_here

# ─── Redis (caching) ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
